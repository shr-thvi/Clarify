# =====================================================
# CLARIFY - Educational Doubt Resolution Platform
# Environment Configuration Template
# =====================================================

# ===== REQUIRED CONFIGURATION =====

# Groq API Key (REQUIRED)
# Get your API key from: https://console.groq.com
# This is essential for AI-powered doubt rewriting
GROQ_API_KEY=your_groq_api_key_here

# ===== OPTIONAL CONFIGURATION =====

# Port (Optional)
# Default: 3000
# Change this if you want to run on a different port
PORT=3000

# Application URL
# The URL where this application is deployed
# Development: http://localhost:3000
# Production: https://yourdomain.com
APP_URL=http://localhost:3000

# CORS Origin (Optional)
# Default: http://localhost:3000
# For production, set this to your domain
CORS_ORIGIN=http://localhost:3000

# Node Environment (Optional)
# Options: development, production
# Default: development
NODE_ENV=development

# ===== OPTIONAL: TRANSLATION SUPPORT =====

# LibreTranslate API Configuration
# For enabling advanced translation features
# Leave empty to skip translation functionality
# LIBRE_TRANSLATE_URL=http://localhost:5000
# LIBRE_TRANSLATE_KEY=your_libre_translate_key

# ===== OPTIONAL: FUTURE EXTENSIONS =====

# Google API Configuration (For future Google-powered features)
# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id

# =====================================================
# DEPLOYMENT NOTES:
# 1. Never commit actual API keys to version control
# 2. Use secure secret management in production
# 3. Set NODE_ENV=production for production deployments
# 4. Update APP_URL to match your domain
# 5. For Docker: Pass these as environment variables
# =====================================================
